{
    "name": "mage2kishan/module-html-sitemap",
    "description": "Theme-agnostic HTML sitemap page for Magento 2 (Hyva + Luma). Renders categories (tree), products (grid), CMS pages, store switcher, and custom links at /sitemap with a built-in client-side search. Extracted from Panth_AdvancedSEO for independent installation.",
    "type": "magento2-module",
    "version": "1.0.2",
    "license": "proprietary",
    "keywords": [
        "magento2",
        "magento2-module",
        "panth",
        "html-sitemap",
        "sitemap",
        "hyva",
        "luma",
        "seo"
    ],
    "require": {
        "php": "~8.1.0||~8.2.0||~8.3.0||~8.4.0",
        "magento/framework": "^103.0",
        "magento/module-store": "^101.0",
        "magento/module-catalog": "^104.0",
        "magento/module-cms": "^104.0",
        "magento/module-eav": "^102.0",
        "mage2kishan/module-core": "^1.0"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Panth\\HtmlSitemap\\": ""
        }
    }
}
