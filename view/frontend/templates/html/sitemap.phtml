<?php
/**
 * HTML Sitemap -- plain PHP, theme-agnostic (Hyva + Luma compatible).
 *
 * No JavaScript framework, no Alpine, no jQuery, no mage-init, no x-magento-init.
 * All styles are inline and scoped to .panth-htmlsitemap so they cannot leak
 * into the host theme. A tiny vanilla JS block handles the search filter
 * and the back-to-top button.
 *
 * @var \Panth\HtmlSitemap\Block\Html\Sitemap $block
 * @var \Magento\Framework\Escaper $escaper
 */

/** @var \Panth\HtmlSitemap\ViewModel\HtmlSitemap $viewModel */
$viewModel = $block->getHtmlSitemapViewModel();

$showCategories  = $viewModel->isShowCategories();
$showProducts    = $viewModel->isShowProducts();
$showCmsPages    = $viewModel->isShowCmsPages();
$showCustomLinks = $viewModel->isShowCustomLinks();
$showStores      = $viewModel->isShowStores();
$showSearchField = $viewModel->isShowSearchField();

$categories  = $showCategories  ? $viewModel->getCategories()  : [];
$products    = $showProducts    ? $viewModel->getProducts()    : [];
$cmsPages    = $showCmsPages    ? $viewModel->getCmsPages()    : [];
$customLinks = $showCustomLinks ? $viewModel->getCustomLinks() : [];
$stores      = $showStores      ? $viewModel->getStores()      : [];

$categoryCount = $categories ? $viewModel->getCategoryCount($categories) : 0;
$productCount  = count($products);
$cmsCount      = count($cmsPages);
$linkCount     = count($customLinks);
$storeCount    = count($stores);
$lastUpdated   = $viewModel->getLastUpdatedTimestamp();

$hasContent = $categoryCount > 0 || $productCount > 0 || $cmsCount > 0 || $linkCount > 0 || $storeCount > 0;

/**
 * Recursive category node renderer with connector-style indentation.
 */
$renderNode = static function (array $node, \Magento\Framework\Escaper $esc) use (&$renderNode): string {
    $name = (string) ($node['name'] ?? '');
    $url  = (string) ($node['url'] ?? '#');
    $html  = '<li class="panth-htmlsitemap__tree-node" data-sitemap-item="' . $esc->escapeHtmlAttr(strtolower($name)) . '">';
    $html .= '<a class="panth-htmlsitemap__tree-link" href="' . $esc->escapeUrl($url) . '">'
          . '<span class="panth-htmlsitemap__tree-bullet" aria-hidden="true"></span>'
          . '<span class="panth-htmlsitemap__tree-label">' . $esc->escapeHtml($name) . '</span>'
          . '</a>';
    if (!empty($node['children']) && is_array($node['children'])) {
        $html .= '<ul class="panth-htmlsitemap__tree-children">';
        foreach ($node['children'] as $child) {
            $html .= $renderNode($child, $esc);
        }
        $html .= '</ul>';
    }
    $html .= '</li>';
    return $html;
};
