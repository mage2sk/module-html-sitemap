<script>
(function () {
    var root = document.getElementById('panth-htmlsitemap');
    if (!root) { return; }

    // Back to top
    var topBtn = root.querySelector('.panth-htmlsitemap__to-top');
    if (topBtn) {
        var toggleTop = function () {
            if ((window.pageYOffset || document.documentElement.scrollTop) > 400) {
                topBtn.classList.add('is-visible');
            } else {
                topBtn.classList.remove('is-visible');
            }
        };
        window.addEventListener('scroll', toggleTop, { passive: true });
        toggleTop();
        topBtn.addEventListener('click', function () {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    }

    // Search filter
    var search = document.getElementById('panth-htmlsitemap-search');
    if (!search) { return; }

    var items = root.querySelectorAll('[data-sitemap-item]');
    var sections = root.querySelectorAll('[data-sitemap-section]');

    var matchesTerm = function (el, term) {
        var own = (el.getAttribute('data-sitemap-item') || '').toLowerCase();
        if (own.indexOf(term) !== -1) { return true; }
        var text = (el.textContent || '').toLowerCase();
        return text.indexOf(term) !== -1;
    };

    search.addEventListener('input', function () {
        var term = (search.value || '').trim().toLowerCase();
        if (!term) {
            root.classList.remove('is-filtering');
            root.classList.remove('has-no-results');
            for (var i = 0; i < items.length; i++) { items[i].style.display = ''; }
            for (var j = 0; j < sections.length; j++) { sections[j].style.display = ''; }
            return;
        }
        root.classList.add('is-filtering');
        var anyMatch = false;
        for (var k = 0; k < items.length; k++) {
            if (matchesTerm(items[k], term)) {
                items[k].style.display = '';
                anyMatch = true;
            } else {
                items[k].style.display = 'none';
            }
        }
        // Hide section if it has no visible items
        for (var s = 0; s < sections.length; s++) {
            var visible = sections[s].querySelectorAll('[data-sitemap-item]');
            var shown = 0;
            for (var v = 0; v < visible.length; v++) {
                if (visible[v].style.display !== 'none') { shown++; }
            }
            sections[s].style.display = shown > 0 ? '' : 'none';
        }
        if (anyMatch) {
            root.classList.remove('has-no-results');
        } else {
            root.classList.add('has-no-results');
        }
    });
})();
</script>
